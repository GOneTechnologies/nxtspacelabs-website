{
  "rewrites": [
    { "source": "/tradepilot",          "destination": "https://trade-pilot-beige.vercel.app/trade" },
    { "source": "/tradepilot/:path*",   "destination": "https://trade-pilot-beige.vercel.app/:path*" },
    { "source": "/login",        "destination": "https://nxtspacelabs-admin.vercel.app/login" },
    { "source": "/dashboard",    "destination": "https://nxtspacelabs-admin.vercel.app/dashboard" },
    { "source": "/kyc",          "destination": "https://nxtspacelabs-admin.vercel.app/kyc" },
    { "source": "/kyc/history",  "destination": "https://nxtspacelabs-admin.vercel.app/kyc/history" },
    { "source": "/users",        "destination": "https://nxtspacelabs-admin.vercel.app/users" },
    { "source": "/talents",      "destination": "https://nxtspacelabs-admin.vercel.app/talents" },
    { "source": "/payouts",      "destination": "https://nxtspacelabs-admin.vercel.app/payouts" },
    { "source": "/reports",      "destination": "https://nxtspacelabs-admin.vercel.app/reports" },
    { "source": "/rooms",        "destination": "https://nxtspacelabs-admin.vercel.app/rooms" },
    { "source": "/rooms-waitlist","destination": "https://nxtspacelabs-admin.vercel.app/rooms-waitlist" },
    { "source": "/audit",        "destination": "https://nxtspacelabs-admin.vercel.app/audit" },
    { "source": "/broadcast",    "destination": "https://nxtspacelabs-admin.vercel.app/broadcast" },
    { "source": "/broadcast/scheduled", "destination": "https://nxtspacelabs-admin.vercel.app/broadcast/scheduled" },
    { "source": "/api/push/broadcast", "destination": "https://nxtspacelabs-admin.vercel.app/api/push/broadcast" },
    { "source": "/api/broadcast/schedule", "destination": "https://nxtspacelabs-admin.vercel.app/api/broadcast/schedule" },
    { "source": "/pricing",       "destination": "https://nxtspacelabs-admin.vercel.app/pricing" },
    { "source": "/pricing/men",   "destination": "https://nxtspacelabs-admin.vercel.app/pricing/men" },
    { "source": "/pricing/women", "destination": "https://nxtspacelabs-admin.vercel.app/pricing/women" },
    { "source": "/admins",       "destination": "https://nxtspacelabs-admin.vercel.app/admins" },
    { "source": "/payments",     "destination": "https://nxtspacelabs-admin.vercel.app/payments" },
    { "source": "/live-calls",   "destination": "https://nxtspacelabs-admin.vercel.app/live-calls" },
    { "source": "/users/:id",    "destination": "https://nxtspacelabs-admin.vercel.app/users/:id" },
    { "source": "/api/auth/:path*", "destination": "https://nxtspacelabs-admin.vercel.app/api/auth/:path*" },
    { "source": "/api/kyc/:path*",     "destination": "https://nxtspacelabs-admin.vercel.app/api/kyc/:path*" },
    { "source": "/api/users/:path*",   "destination": "https://nxtspacelabs-admin.vercel.app/api/users/:path*" },
    { "source": "/api/payouts/:path*", "destination": "https://nxtspacelabs-admin.vercel.app/api/payouts/:path*" },
    { "source": "/api/reports/:path*", "destination": "https://nxtspacelabs-admin.vercel.app/api/reports/:path*" },
    { "source": "/api/rooms/:path*",   "destination": "https://nxtspacelabs-admin.vercel.app/api/rooms/:path*" },
    { "source": "/api/pricing",        "destination": "https://nxtspacelabs-admin.vercel.app/api/pricing" },
    { "source": "/api/pricing/:path*", "destination": "https://nxtspacelabs-admin.vercel.app/api/pricing/:path*" },
    { "source": "/api/payments",       "destination": "https://nxtspacelabs-admin.vercel.app/api/payments" },
    { "source": "/api/payments/:path*","destination": "https://nxtspacelabs-admin.vercel.app/api/payments/:path*" },
    { "source": "/api/calls/:path*",   "destination": "https://nxtspacelabs-admin.vercel.app/api/calls/:path*" },
    { "source": "/api/talents/:path*", "destination": "https://nxtspacelabs-admin.vercel.app/api/talents/:path*" },
    { "source": "/api/admins",         "destination": "https://nxtspacelabs-admin.vercel.app/api/admins" },
    { "source": "/api/admins/:path*",  "destination": "https://nxtspacelabs-admin.vercel.app/api/admins/:path*" },
    { "source": "/api/cron/:path*",    "destination": "https://nxtspacelabs-admin.vercel.app/api/cron/:path*" },
    { "source": "/_next/:path*",   "destination": "https://nxtspacelabs-admin.vercel.app/_next/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",        "value": "camera=(), microphone=(), geolocation=(), interest-cohort=(), payment=()" },
        { "key": "Cross-Origin-Opener-Policy","value": "same-origin" },
        { "key": "X-DNS-Prefetch-Control",    "value": "on" },
        { "key": "Content-Security-Policy",   "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://js.hcaptcha.com https://*.hcaptcha.com https://va.vercel-scripts.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://*.hcaptcha.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://cdn.jsdelivr.net https://hcaptcha.com https://*.hcaptcha.com https://vitals.vercel-insights.com; frame-src https://newassets.hcaptcha.com https://*.hcaptcha.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; worker-src 'self' blob:; media-src 'self'" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }
      ]
    },
    {
      "source": "/(sitemap.xml|robots.txt|site.webmanifest|logo.svg)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
